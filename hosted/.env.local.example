# Copy to .env.local and fill in.
#
# `npx convex dev` writes CONVEX_DEPLOYMENT here and prints your deployment URL —
# put that URL in NEXT_PUBLIC_CONVEX_URL below.
NEXT_PUBLIC_CONVEX_URL=https://YOUR-DEPLOYMENT.convex.cloud

# A long random string. Set the SAME value on the Convex deployment with:
#   npx convex env set HYPERPORTAL_ADMIN_KEY <this-value>
# The MCP server and seed script authenticate with it; recipients never see it.
HYPERPORTAL_ADMIN_KEY=change-me-to-a-long-random-string

# Where recipient links point (the Next app's public origin).
HYPERPORTAL_BASE_URL=http://localhost:3000
